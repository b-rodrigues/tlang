{
  "grammars": [
    {
      "name": "t",
      "camelcase": "T",
      "scope": "source.t",
      "path": ".",
      "file-types": [
        "t"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "locals": "queries/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "EUPL-1.2",
    "description": "Tree-sitter grammar for the T programming language",
    "links": {
      "repository": "https://github.com/b-rodrigues/tlang"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
